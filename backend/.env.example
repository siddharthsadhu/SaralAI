# ═══════════════════════════════════════════════════════════
# SaralAI Backend — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ═══════════════════════════════════════════════════════════

# ─── Sarvam AI (Single key for ALL 4 services) ─────────────
# Get your key from: https://dashboard.sarvam.ai
# One key covers: Saaras v3 (STT) + sarvam-m (LLM) + Mayura v1 (Translation) + Bulbul v3 (TTS)
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PostgreSQL Database ───────────────────────────────────
# Railway auto-generates this when you add a PostgreSQL service.
# For local dev: postgresql://postgres:postgres@localhost:5432/saralai
# For SQLite local dev (no PostgreSQL needed): leave as default in config.py
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/saralai

# ─── Application# ── App Settings ───────────────────────────────────────────────
APP_ENV=development
DEBUG=true
APP_VERSION=1.0.0

# ── Auth Settings ──────────────────────────────────────────────
# Google Auth (Required for login)
GOOGLE_CLIENT_ID=your_google_client_id_here
JWT_SECRET=your_secret_key_used_for_signing_jwt_tokens          # development / production
DEBUG=true                   # Set to false in production
APP_VERSION=1.0.0

# ─── CORS (Which frontends are allowed to call this API) ───
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=60   # Per IP address per minute
